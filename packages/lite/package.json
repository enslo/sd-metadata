{
  "name": "@enslo/sd-metadata-lite",
  "version": "1.1.0",
  "description": "Lightweight AI image metadata reader for bookmarklets",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.ja.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown && tsx build-iife.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enslo/sd-metadata.git",
    "directory": "packages/lite"
  },
  "keywords": [
    "stable-diffusion",
    "ai-image",
    "metadata-parser",
    "lightweight",
    "bookmarklet"
  ],
  "author": "Ernest Croft",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/enslo/sd-metadata/issues"
  },
  "homepage": "https://sd-metadata-lite.pages.dev",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "^0.28.0",
    "terser": "^5.48.0",
    "tsdown": "catalog:",
    "tsx": "^4.22.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
